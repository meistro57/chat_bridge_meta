APP_NAME="Chat Bridge"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://0.0.0.0:20000
APP_PORT=20000
APP_VERSION=0.8.0
APP_READ_ONLY_MODE=false
APP_READ_ONLY_ALLOW_INFRA_WRITES=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# For local development (SQLite)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# For Docker/Production (PostgreSQL)
# DB_CONNECTION=pgsql
# DB_HOST=postgres
# DB_PORT=15432
# DB_DATABASE=chatbridge
# DB_USERNAME=chatbridge
# DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# For Docker, use: redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# For Docker, use: redis
QUEUE_CONNECTION=database

# For Docker, use: redis
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=16379
REDIS_QUEUE_RETRY_AFTER=1300

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSocket Server)
REVERB_APP_ID=chatbridge
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=20001
REVERB_SERVER_PORT=20001
REVERB_SCHEME=http

# For Docker
# REVERB_HOST=reverb
# REVERB_SERVER_HOST=0.0.0.0
# REVERB_SERVER_PORT=20001

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Qdrant Vector Database for RAG
QDRANT_ENABLED=true
QDRANT_HOST=localhost
QDRANT_PORT=16333
QDRANT_GRPC_PORT=16334

# For Docker
# QDRANT_HOST=qdrant

# AI Provider API Keys (add your own)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-001
# BEDROCK_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0
# BEDROCK_RUNTIME_BASE_URL=

# Embedding vector size — must match the Qdrant collection's vector size.
# 3072 = gemini-embedding-001 (shared standard across Chat Bridge, meta-bridge, FrontPocket).
EMBEDDING_VECTOR_SIZE=3072

# Meta Bridge — read-only cross-collection RAG against the meta-bridge Qdrant collections
# (same Qdrant instance/host as QDRANT_HOST above, just different collection names).
MB_QDRANT_COLLECTION_CLAIMS=mb_claims
MB_QDRANT_COLLECTION_CHUNKS=mb_chunks
MB_QDRANT_COLLECTION_SOURCES=mb_sources
MB_QDRANT_COLLECTION_REFLECTIONS=meta_reflections
MB_QDRANT_REFLECTION_VECTOR=summary_vec
MB_QDRANT_SCORE_THRESHOLD=0.5

# AI Tool Calling (MCP Integration)
AI_TOOLS_ENABLED=true
AI_MAX_TOOL_ITERATIONS=5
# RAG backend: auto|qdrant|database
AI_RAG_DRIVER=auto
AI_ACTIVE_AUTO_RECOVERY_ENABLED=true
AI_ACTIVE_AUTO_RECOVERY_LIMIT=100
AI_ACTIVE_KICKSTART_AFTER_SECONDS=90
AI_ACTIVE_KICKSTART_COOLDOWN_SECONDS=120
AI_ACTIVE_FORCE_UNLOCK_AFTER_SECONDS=600

# Discord conversation broadcasting
DISCORD_STREAMING_ENABLED=true
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_THREAD_AUTO_CREATE=true
DISCORD_CIRCUIT_BREAKER_THRESHOLD=5
DISCORD_EMBED_COLOR_A=3905270
DISCORD_EMBED_COLOR_B=9136174
DISCORD_MAX_EMBED_DESCRIPTION=3900

# Discourse conversation broadcasting
DISCOURSE_STREAMING_ENABLED=false
# Topic-post mode (Discourse API key)
# DISCOURSE_BASE_URL=https://your-discourse.example.com
# DISCOURSE_API_KEY=your-discourse-api-key
# DISCOURSE_API_USERNAME=chat-bridge
# DISCOURSE_DEFAULT_CATEGORY_ID=12
# DISCOURSE_DEFAULT_TAGS=chat-bridge,ai-session
# Discourse Chat plugin webhook mode
DISCOURSE_CHAT_ENABLED=false
# DISCOURSE_CHAT_WEBHOOK_URL=https://your-discourse.example.com/chat/hooks/your-key.json
DISCOURSE_TIMEOUT_SECONDS=15
DISCOURSE_CONNECT_TIMEOUT_SECONDS=5
DISCOURSE_CIRCUIT_BREAKER_THRESHOLD=5

APP_NAME="Chat Bridge"
APP_ENV=production
APP_KEY=base64:mCvgX/LP1s+vikje6mQjLOrLCE+EqMpjwGBUMucFCCY=
APP_DEBUG=false
APP_URL=http://localhost:18080
APP_PORT=18080
APP_VERSION=0.8.0
LOCAL_UID=1000
LOCAL_GID=1000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# PostgreSQL Database (Docker)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=15432
DB_DATABASE=chatbridge
DB_USERNAME=chatbridge
DB_PASSWORD=secret

# Redis (Docker)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=16379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSocket Server)
REVERB_APP_ID=chatbridge
REVERB_APP_KEY=change-me-reverb-key
REVERB_APP_SECRET=change-me-reverb-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=18081
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Qdrant Vector Database for RAG
QDRANT_ENABLED=true
QDRANT_HOST=qdrant
QDRANT_PORT=16333
QDRANT_GRPC_PORT=16334

# AI Provider API Keys (add your own)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
